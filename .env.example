# AceFit Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# SUPABASE (Required)
# Get these from: https://supabase.com → Your Project → Settings → API
# ============================================================
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# APP URL (Update for production)
# ============================================================
VITE_APP_URL=http://localhost:5173

# ============================================================
# RESEND EMAIL (Optional but recommended)
# Get free API key from: https://resend.com
# No domain required for onboarding/transactional emails
# ============================================================
VITE_RESEND_API_KEY=re_your_api_key_here

# ============================================================
# OPAY PAYMENT (Optional)
# Get credentials from: https://merchant.opayweb.com
# ============================================================
VITE_OPAY_MERCHANT_ID=your_merchant_id
VITE_OPAY_PUBLIC_KEY=your_public_key
VITE_OPAY_BASE_URL=https://cashier.opayweb.com

# ============================================================
# WHATSAPP ORDER (Pre-configured for AceFit)
# ============================================================
VITE_WHATSAPP_PRIMARY=2347025692097
VITE_WHATSAPP_SECONDARY=2349153040271
