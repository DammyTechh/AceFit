# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-key

# ── Paystack ─────────────────────────────────────────────────
# Get from https://dashboard.paystack.com/#/settings/developer
VITE_PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key
# pk_test_xxx for testing, pk_live_xxx for production

# ── Admin ────────────────────────────────────────────────────
VITE_ADMIN_EMAIL=admin@acefit.com
VITE_ADMIN_PASSWORD=AceFit@2026!

# ── App ──────────────────────────────────────────────────────
VITE_APP_URL=https://acefit.netlify.app

# ── Fez Delivery (optional live delivery quotes) ─────────────
# Leave 'false' to keep using your admin delivery zones only.
# Set 'true' AFTER deploying the `fez` edge function + secrets below.
VITE_FEZ_ENABLED=false

# ── Supabase Edge Function Secrets (set via CLI, not here) ───
# supabase secrets set RESEND_API_KEY=re_xxxxxxxxxxxx
# supabase secrets set PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxx
# Fez (only if VITE_FEZ_ENABLED=true):
# supabase secrets set FEZ_BASE_URL=https://apisandbox.fezdelivery.co/v1
# supabase secrets set FEZ_SECRET_KEY=your_fez_secret_key
# supabase secrets set FEZ_COST_PATH=/order-price   # confirm exact path in Fez dashboard
